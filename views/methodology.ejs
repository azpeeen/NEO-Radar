          <text x="360" y="196" font-family="JetBrains Mono" font-size="9" fill="rgba(255,255,255,0.4)" text-anchor="middle">frozen · per-frame</text>

          <text x="550" y="32" font-family="JetBrains Mono" font-size="11" letter-spacing="2" fill="#ff8a55" text-anchor="middle">RENDERER · PRESENTATION</text>
