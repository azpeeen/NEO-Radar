<%- include('partials/head', { title: neo.name + ' · Asteroid Dossier — NEO Radar' }) %>

<style>
  body { overflow-x: hidden; }
  main { position: relative; z-index: 1; max-width: 1320px; margin: 0 auto; padding: 0 40px; }
  .a-header { padding: 80px 0 56px; border-bottom: 1px solid var(--line); display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: end; }
  .a-header .crumb { display: flex; align-items: center; gap: 10px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 24px; }
  .a-header .crumb a { color: var(--ink-3); text-decoration: none; } .a-header .crumb a:hover { color: var(--ink); }
  .a-header h1 { font-family: var(--font-display); font-weight: 500; letter-spacing: -0.035em; line-height: 0.98; font-size: clamp(56px, 7vw, 104px); margin: 0 0 16px; }
  .a-header h1 .common { display: block; font-family: var(--font-mono); font-size: 14px; color: var(--ink-3); letter-spacing: 0.16em; text-transform: uppercase; font-weight: 400; margin-bottom: 8px; }
  .a-header .summary { color: var(--ink-2); font-size: 16px; line-height: 1.6; max-width: 580px; margin: 20px 0 0; }
  .countdown { padding: 28px; background: linear-gradient(180deg, rgba(255,107,43,0.08), rgba(255,107,43,0.02)); border: 1px solid rgba(255,107,43,0.25); border-radius: var(--r-lg); }
  .countdown .label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber); margin-bottom: 14px; }
  .countdown .time { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.06); border-radius: 8px; overflow: hidden; margin-bottom: 18px; }
  .countdown .time .cell { padding: 12px; text-align: center; background: rgba(8,10,18,0.6); }
  .countdown .time .v { font-family: var(--font-display); font-weight: 500; font-size: 36px; letter-spacing: -0.025em; line-height: 1; font-variant-numeric: tabular-nums; }
  .countdown .time .k { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-top: 6px; }
  .countdown .meta { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); }
  .countdown .meta strong { color: var(--ink); font-weight: 500; }
  .a-section { padding: 80px 0; border-bottom: 1px solid var(--line); display: grid; grid-template-columns: 240px 1fr; gap: 56px; }
  .a-section .stub { position: sticky; top: 80px; align-self: start; }
  .a-section .stub .n { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--ink-4); margin-bottom: 8px; }
  .a-section .stub h2 { font-family: var(--font-display); font-weight: 500; font-size: 28px; letter-spacing: -0.025em; line-height: 1.1; margin: 0; }
  .a-section .stub p { color: var(--ink-3); font-size: 13px; margin: 14px 0 0; line-height: 1.55; }
  .elements-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--r-lg); overflow: hidden; margin-bottom: 24px; }
  .elements-grid .cell { padding: 22px 24px; background: rgba(10,12,22,0.5); }
  .elements-grid .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 12px; }
  .elements-grid .v { font-family: var(--font-display); font-weight: 500; font-size: 26px; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .elements-grid .v small { font-family: var(--font-mono); font-size: 13px; color: var(--ink-3); font-weight: 400; margin-left: 4px; }
  .elements-grid .d { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-3); margin-top: 6px; line-height: 1.4; }
  .mini-orbit { height: 380px; border-radius: var(--r-lg); border: 1px solid var(--line); background: radial-gradient(ellipse at center, rgba(26,108,246,0.05), transparent 60%), #06070d; position: relative; overflow: hidden; }
  .mini-orbit canvas { width: 100%; height: 100%; display: block; }
  .mini-orbit .legend { position: absolute; top: 14px; left: 14px; display: flex; gap: 14px; }
  .mini-orbit .legend .it { display: flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .mini-orbit .legend .it .d { width: 8px; height: 8px; border-radius: 50%; }
  table.approaches { width: 100%; margin-top: 24px; border-collapse: collapse; }
  table.approaches thead th { text-align: left; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); padding: 14px 16px; border-bottom: 1px solid var(--line); }
  table.approaches tbody td { padding: 16px; border-bottom: 1px solid var(--line); font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-2); font-variant-numeric: tabular-nums; }
  table.approaches tbody td.year { color: var(--ink); font-size: 13px; }
  table.approaches tbody td.name { font-family: var(--font-display); font-weight: 500; font-size: 14px; color: var(--ink); letter-spacing: -0.01em; }
  table.approaches tbody tr.now td { background: rgba(255,107,43,0.05); }
  table.approaches tbody tr.now td.year { color: var(--amber); }
  table.approaches tbody tr:last-child td { border-bottom: none; }
  table.approaches .past { opacity: 0.55; }
  .jpl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .jpl-stat { padding: 24px; border: 1px solid var(--line); border-radius: var(--r-lg); background: rgba(8,10,18,0.5); }
  .jpl-stat.feature { background: linear-gradient(180deg, rgba(26,108,246,0.10), rgba(26,108,246,0.02)); border-color: rgba(26,108,246,0.3); }
  .jpl-stat .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 14px; }
  .jpl-stat .v { font-family: var(--font-display); font-weight: 500; font-size: 40px; letter-spacing: -0.025em; line-height: 1; font-variant-numeric: tabular-nums; }
  .jpl-stat .v small { font-family: var(--font-mono); font-size: 14px; color: var(--ink-3); font-weight: 400; margin-left: 5px; }
  .jpl-stat .d { color: var(--ink-3); font-size: 13px; margin-top: 14px; line-height: 1.55; }
  .pert-toggle { display: inline-flex; background: rgba(8,10,18,0.6); border: 1px solid var(--line); border-radius: 999px; padding: 3px; margin-bottom: 24px; }
  .pert-toggle button { background: transparent; border: none; padding: 8px 18px; border-radius: 999px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); cursor: pointer; transition: all 180ms; }
  .pert-toggle button.active { background: var(--cobalt); color: white; box-shadow: 0 0 12px var(--cobalt-glow); }
  .pert-canvas { height: 320px; border-radius: var(--r-lg); border: 1px solid var(--line); background: #06070d; position: relative; overflow: hidden; }
  .pert-canvas canvas { width: 100%; height: 100%; display: block; }
  .pert-diff { margin-top: 16px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .pert-diff .stat { padding: 16px; border: 1px solid var(--line); border-radius: 8px; background: rgba(8,10,18,0.5); }
  .pert-diff .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 8px; }
  .pert-diff .v { font-family: var(--font-display); font-weight: 500; font-size: 22px; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .pert-diff .v small { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); font-weight: 400; margin-left: 3px; }
  .compare-strip { display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: var(--r-lg); overflow: hidden; background: rgba(8,10,18,0.4); }
  .compare-strip .row { display: grid; grid-template-columns: 200px 1fr 140px; align-items: center; gap: 24px; padding: 22px 24px; border-top: 1px solid var(--line); }
  .compare-strip .row:first-child { border-top: none; }
  .compare-strip .row.this { background: rgba(255,107,43,0.05); }
  .compare-strip .row .lbl { font-family: var(--font-display); font-weight: 500; font-size: 15px; letter-spacing: -0.01em; }
  .compare-strip .row .lbl small { display: block; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-4); letter-spacing: 0.08em; margin-top: 4px; }
  .compare-strip .scale { height: 4px; border-radius: 2px; background: rgba(255,255,255,0.06); position: relative; }
  .compare-strip .scale .fill { position: absolute; inset: 0 auto 0 0; border-radius: 2px; background: linear-gradient(90deg, var(--ink-3), var(--ink-2)); }
  .compare-strip .row.this .scale .fill { background: linear-gradient(90deg, var(--amber), var(--amber-soft)); box-shadow: 0 0 12px var(--amber-glow); }
  .compare-strip .row .val { text-align: right; font-family: var(--font-mono); font-size: 13px; color: var(--ink-2); font-variant-numeric: tabular-nums; }
  .context-note { margin-top: 24px; padding: 24px; border-left: 2px solid var(--cobalt); background: rgba(26,108,246,0.04); border-radius: 0 8px 8px 0; font-size: 15px; line-height: 1.6; color: var(--ink-2); }
  .context-note strong { color: var(--ink); font-weight: 500; }
  @media (max-width: 900px) {
    .a-header { grid-template-columns: 1fr; gap: 32px; }
    .a-section { grid-template-columns: 1fr; gap: 24px; }
    .a-section .stub { position: static; }
    .elements-grid { grid-template-columns: 1fr 1fr; }
    .jpl-grid { grid-template-columns: 1fr; }
    .pert-diff { grid-template-columns: 1fr; }
    .compare-strip .row { grid-template-columns: 1fr; gap: 12px; }
  }
</style>

<div class="space-bg" aria-hidden="true"></div>

<%- include('partials/nav') %>

<main>
  <section class="a-header" data-screen-label="03 Asteroid — Header">
    <div>
      <div class="crumb">
        <a href="/">Catalog</a><span>›</span><span>NEAs</span><span>›</span>
        <span style="color:var(--ink-2)"><%= neo.designation %></span>
      </div>
      <h1>
        <span class="common"><%= neo.designation %> · <%= neo.group %> Group</span>
        <%= neo.name %>
      </h1>
      <div style="display:flex;align-items:center;gap:12px;margin-top:10px;">
        <span class="risk <%= neo.riskLevel %>"><%= neo.riskLevel.charAt(0).toUpperCase() + neo.riskLevel.slice(1) %></span>
        <span class="jpl-badge subtle">Data · JPL Horizons</span>
        <span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-4);letter-spacing:0.1em;">Updated 2026·05·26 14:21 UTC</span>
      </div>
      <p class="summary">
        Discovered in 2004, <%= neo.name %> is an <%= neo.group %>-group asteroid whose
        <%= new Date(neo.nextApproach).getFullYear() %> close approach will bring it to
        <%= neo.missDist_km.toLocaleString() %> km from Earth — <%= neo.missDist_ld %> lunar
        distances — at <%= neo.velocity_kms %> km/s.
      </p>
    </div>

    <div class="countdown">
      <div class="label">⊙ Next Close Approach</div>
      <div class="time">
        <div class="cell"><div class="v num" id="cd-d">—</div><div class="k">Days</div></div>
        <div class="cell"><div class="v num" id="cd-h">—</div><div class="k">Hours</div></div>
        <div class="cell"><div class="v num" id="cd-m">—</div><div class="k">Min</div></div>
        <div class="cell"><div class="v num" id="cd-s">—</div><div class="k">Sec</div></div>
      </div>
      <div class="meta">
        <span><strong><%= neo.nextApproach.replace(/-/g, '·') %></strong></span>
        <span>Miss distance <strong><%= neo.missDist_km.toLocaleString() %> km</strong></span>
      </div>
    </div>
  </section>

  <section class="a-section" data-screen-label="03 Asteroid — Orbital Data">
    <div class="stub">
      <div class="n">01</div>
      <h2>Orbital Elements</h2>
      <p>Keplerian elements from JPL Horizons — epoch JD 2461000.5, heliocentric ecliptic J2000.</p>
    </div>
    <div>
      <div class="elements-grid">
        <div class="cell">
          <div class="k">Semi-major (a)</div>
          <div class="v"><%= neo.a %> <small>AU</small></div>
          <div class="d">Period <%= (Math.pow(neo.a, 1.5) * 365.25).toFixed(1) %> d</div>
        </div>
        <div class="cell">
          <div class="k">Eccentricity (e)</div>
          <div class="v"><%= neo.e %></div>
          <div class="d"><%= neo.group %>-type, crosses Earth's orbit</div>
        </div>
        <div class="cell">
          <div class="k">Inclination (i)</div>
          <div class="v"><%= neo.i %><small>°</small></div>
          <div class="d">w.r.t. ecliptic plane</div>
        </div>
        <div class="cell">
          <div class="k">Longitude (Ω)</div>
          <div class="v"><%= neo.Omega %><small>°</small></div>
          <div class="d">Ascending node</div>
        </div>
        <div class="cell">
          <div class="k">Arg. periapsis (ω)</div>
          <div class="v"><%= neo.omega %><small>°</small></div>
          <div class="d">Orientation in plane</div>
        </div>
        <div class="cell">
          <div class="k">Mean anomaly (M)</div>
          <div class="v"><%= neo.M %><small>°</small></div>
          <div class="d">At epoch JD 2461000.5</div>
        </div>
      </div>

      <div class="mini-orbit">
        <div class="legend">
          <div class="it"><span class="d" style="background:#ffd87a"></span>Sun</div>
          <div class="it"><span class="d" style="background:#4f8fff"></span>Earth · 1.00 AU</div>
          <div class="it"><span class="d" style="background:#ff8a55"></span><%= neo.name %> · <%= neo.a %> AU</div>
        </div>
        <canvas id="mini-orbit-canvas"></canvas>
      </div>

      <table class="approaches">
        <thead><tr><th>Year</th><th>Date</th><th>Miss · km</th><th>Miss · LD</th><th>Velocity</th><th>Body</th></tr></thead>
        <tbody>
          <tr class="past"><td class="year">2004</td><td>Dec 21</td><td>14,200,000</td><td>36.93</td><td>5.86 km/s</td><td class="name">Earth</td></tr>
          <tr class="past"><td class="year">2013</td><td>Jan 09</td><td>14,460,000</td><td>37.60</td><td>5.84 km/s</td><td class="name">Earth</td></tr>
          <tr class="past"><td class="year">2021</td><td>Mar 06</td><td>16,910,000</td><td>43.98</td><td>5.79 km/s</td><td class="name">Earth</td></tr>
          <tr class="now"><td class="year"><%= new Date(neo.nextApproach).getFullYear() %></td><td><%= new Date(neo.nextApproach).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></td><td><strong><%= neo.missDist_km.toLocaleString() %></strong></td><td><strong><%= neo.missDist_ld %></strong></td><td><%= neo.velocity_kms %> km/s</td><td class="name">Earth</td></tr>
          <tr><td class="year">2036</td><td>Apr 13</td><td>27,840,000</td><td>72.39</td><td>6.21 km/s</td><td class="name">Earth</td></tr>
          <tr><td class="year">2051</td><td>Apr 12</td><td>1,930,000</td><td>5.02</td><td>9.32 km/s</td><td class="name">Earth</td></tr>
          <tr><td class="year">2066</td><td>Apr 13</td><td>11,640,000</td><td>30.28</td><td>5.94 km/s</td><td class="name">Earth</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="a-section" data-screen-label="03 Asteroid — JPL Accuracy">
    <div class="stub">
      <div class="n">02</div>
      <h2>JPL Accuracy</h2>
      <p>Solution quality, observation arc, and position uncertainty — pulled from JPL Horizons.</p>
    </div>
    <div>
      <div class="jpl-grid">
        <div class="jpl-stat feature">
          <div class="k">Position uncertainty (σ)</div>
          <div class="v">412 <small>km</small></div>
          <div class="d">3σ along-track deviation at the close approach, propagated forward from JPL Horizons covariance matrix.</div>
        </div>
        <div class="jpl-stat">
          <div class="k">Observation arc</div>
          <div class="v">21.7 <small>years</small></div>
          <div class="d">8,792 individual astrometric observations across 47 observatories.</div>
        </div>
        <div class="jpl-stat">
          <div class="k">Last updated</div>
          <div class="v">14h <small>ago</small></div>
          <div class="d">JPL Horizons solution K224/56 · pulled 2026·05·26 14:21 UTC into local cache.</div>
        </div>
        <div class="jpl-stat">
          <div class="k">Condition code</div>
          <div class="v">0 <small>/ 9</small></div>
          <div class="d">0 = essentially deterministic. This trajectory is among the most precisely known in the catalog.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="a-section" data-screen-label="03 Asteroid — Jupiter Perturbation">
    <div class="stub">
      <div class="n">03</div>
      <h2>Jupiter Perturbation</h2>
      <p>How outer-planet gravity bends the trajectory between now and the 2068 century-of-uncertainty mark.</p>
    </div>
    <div>
      <div class="pert-toggle">
        <button class="active" data-mode="on">With Jupiter</button>
        <button data-mode="off">Without Jupiter</button>
        <button data-mode="diff">Difference</button>
      </div>
      <div class="pert-canvas"><canvas id="pert-canvas"></canvas></div>
      <div class="pert-diff">
        <% if (perturbData && perturbData.stats) { %>
        <div class="stat"><div class="k">Δposition · 2068</div><div class="v"><%= perturbData.stats.finalDevKm.toLocaleString() %> <small>km</small></div></div>
        <div class="stat"><div class="k">Δvelocity · cumulative</div><div class="v"><%= perturbData.stats.dvKms %> <small>km/s</small></div></div>
        <div class="stat"><div class="k">Max divergence</div><div class="v"><%= perturbData.stats.maxDevKm.toLocaleString() %> <small>km</small></div></div>
        <% } else { %>
        <div class="stat"><div class="k">Δposition · 2068</div><div class="v">— <small>km</small></div></div>
        <div class="stat"><div class="k">Δvelocity · cumulative</div><div class="v">— <small>km/s</small></div></div>
        <div class="stat"><div class="k">Max divergence</div><div class="v">— <small>km</small></div></div>
        <% } %>
      </div>
    </div>
  </section>

  <section class="a-section" data-screen-label="03 Asteroid — Context">
    <div class="stub">
      <div class="n">04</div>
      <h2>What does <%= neo.missDist_km.toLocaleString() %> km mean?</h2>
      <p>A tasteful, accurate comparison — without the clickbait. Against other known orbital references.</p>
    </div>
    <div>
      <div class="compare-strip">
        <div class="row"><div class="lbl">Low Earth Orbit<small>ISS · 408 km</small></div><div class="scale"><div class="fill" style="width:0.5%"></div></div><div class="val">408 km</div></div>
        <div class="row"><div class="lbl">Geostationary belt<small>Communications satellites</small></div><div class="scale"><div class="fill" style="width:50%"></div></div><div class="val">35,786 km</div></div>
        <div class="row this"><div class="lbl"><%= neo.name %><small>This object's close approach</small></div><div class="scale"><div class="fill" style="width:<%= Math.min(99, (neo.missDist_km / 384400 * 100)).toFixed(1) %>%"></div></div><div class="val"><%= neo.missDist_km.toLocaleString() %> km</div></div>
        <div class="row"><div class="lbl">Moon<small>Mean orbital distance</small></div><div class="scale"><div class="fill" style="width:100%"></div></div><div class="val">384,400 km</div></div>
      </div>
      <div class="context-note">
        <%= neo.name %> will pass at <strong><%= neo.missDist_ld %> lunar distances</strong> — closer than
        the geostationary belt that hosts your TV and GPS satellites.
        At <%= neo.velocity_kms %> km/s relative velocity, this is one of the most significant
        close approaches of our generation.
      </div>
    </div>
  </section>
</main>

<footer class="footer" data-screen-label="03 Asteroid — Footer">
  <div style="display:flex;align-items:center;gap:12px;">
    <svg width="20" height="20" viewBox="0 0 64 64" fill="none"><g transform="translate(32 32) rotate(-18)"><ellipse cx="0" cy="0" rx="26" ry="9" fill="none" stroke="currentColor" stroke-width="2.4"/><circle cx="18" cy="-5.4" r="2.2" fill="currentColor"/><circle cx="-15" cy="5.6" r="2.2" fill="currentColor"/></g><path d="M32 6 L34.6 30 L48 32 L34.6 34 L32 58 L29.4 34 L16 32 L29.4 30 Z" fill="currentColor"/></svg>
    <span class="credit">Built with JPL Horizons · NASA NeoWs</span>
  </div>
  <div class="links"><a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a><a href="/methodology">Methodology</a><a href="#">About</a></div>
  <span class="credit">© 2026 NEO Radar</span>
</footer>

<script>
// Physics data bridge — computed server-side via integrator.js
window.PERTURB_DATA = <%- perturbData ? JSON.stringify({
  epochs: perturbData.epochs,
  devKm:  perturbData.devKm,
  stats:  perturbData.stats,
}) : 'null' %>;

// Countdown to neo.nextApproach
(function() {
  const target = new Date('<%- neo.nextApproach %>T21:46:00Z');
  function tick() {
    let diff = Math.max(0, target - new Date()) / 1000;
    const d = Math.floor(diff / 86400); diff %= 86400;
    const h = Math.floor(diff / 3600);  diff %= 3600;
    const m = Math.floor(diff / 60);
    const s = Math.floor(diff % 60);
    document.getElementById('cd-d').textContent = String(d);
    document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
    document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
  }
  tick(); setInterval(tick, 1000);
})();

// Mini orbit canvas
(function() {
  const cv = document.getElementById('mini-orbit-canvas');
  const ctx = cv.getContext('2d');
  let W, H, DPR;
  function resize() {
    const r = cv.parentElement.getBoundingClientRect();
    DPR = Math.max(1, window.devicePixelRatio || 1);
    W = r.width; H = r.height;
    cv.width = W*DPR; cv.height = H*DPR;
    cv.style.width = W+'px'; cv.style.height = H+'px';
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  }
  resize(); window.addEventListener('resize', resize);

  function solveKepler(M, e) {
    let E = M + e*Math.sin(M);
    for (let k=0; k<8; k++) E -= (E - e*Math.sin(E) - M) / (1 - e*Math.cos(E));
    return E;
  }
  function orbitPos(o, t) {
    const period = Math.pow(o.a, 1.5);
    const M = ((t/365.25)/period) * 2*Math.PI + (o.phase || 0);
    const E = solveKepler(M, o.e);
    const x = o.a*(Math.cos(E)-o.e), y = o.a*Math.sqrt(1-o.e*o.e)*Math.sin(E);
    const ang = ((o.w||0)+(o.om||0))*Math.PI/180;
    return { x:x*Math.cos(ang)-y*Math.sin(ang), y:x*Math.sin(ang)+y*Math.cos(ang) };
  }

  const earth = { a:1.0, e:0.017, om:0, w:0, phase:0 };
  const neo   = { a:<%- neo.a %>, e:<%- neo.e %>, om:<%- neo.Omega %>, w:<%- neo.omega %>, phase:1.5 };
  let t0 = performance.now();

  function draw(t) {
    const T = (t - t0) * 0.05;
    const px = 110, cx = W/2, cy = H/2;
    ctx.clearRect(0, 0, W, H);
    ctx.strokeStyle = 'rgba(255,255,255,0.04)'; ctx.lineWidth = 1;
    for (let r=0.5; r<=2; r+=0.5) { ctx.beginPath(); ctx.arc(cx, cy, r*px, 0, Math.PI*2); ctx.stroke(); }
    const sg = ctx.createRadialGradient(cx,cy,0,cx,cy,40);
    sg.addColorStop(0,'rgba(255,220,160,0.7)'); sg.addColorStop(1,'rgba(255,180,100,0)');
    ctx.fillStyle=sg; ctx.fillRect(cx-40,cy-40,80,80);
    ctx.fillStyle='#ffd87a'; ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2); ctx.fill();
    function drawOrb(o, color, alpha) {
      ctx.beginPath();
      for (let k=0; k<=120; k++) {
        const Mt=(k/120)*2*Math.PI+(o.phase||0),E=solveKepler(Mt,o.e),x=o.a*(Math.cos(E)-o.e),y=o.a*Math.sqrt(1-o.e*o.e)*Math.sin(E),ang=((o.w||0)+(o.om||0))*Math.PI/180,wx=x*Math.cos(ang)-y*Math.sin(ang),wy=x*Math.sin(ang)+y*Math.cos(ang);
        const sx=cx+wx*px, sy=cy+wy*px;
        if(k===0) ctx.moveTo(sx,sy); else ctx.lineTo(sx,sy);
      }
      ctx.strokeStyle=color; ctx.globalAlpha=alpha; ctx.lineWidth=1; ctx.stroke(); ctx.globalAlpha=1;
    }
    drawOrb(earth,'rgba(79,143,255,1)',0.6); drawOrb(neo,'rgba(255,138,85,1)',0.7);
    const ep=orbitPos(earth,T), ap=orbitPos(neo,T);
    const eg=ctx.createRadialGradient(cx+ep.x*px,cy+ep.y*px,0,cx+ep.x*px,cy+ep.y*px,14);
    eg.addColorStop(0,'#4f8fff'); eg.addColorStop(0.5,'rgba(79,143,255,0.3)'); eg.addColorStop(1,'rgba(79,143,255,0)');
    ctx.fillStyle=eg; ctx.fillRect(cx+ep.x*px-20,cy+ep.y*px-20,40,40);
    ctx.fillStyle='#4f8fff'; ctx.beginPath(); ctx.arc(cx+ep.x*px,cy+ep.y*px,4,0,Math.PI*2); ctx.fill();
    const pulse=3+Math.sin(t*0.003)*0.7;
    ctx.fillStyle='rgba(255,138,85,0.2)'; ctx.beginPath(); ctx.arc(cx+ap.x*px,cy+ap.y*px,pulse+4,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#ff8a55'; ctx.beginPath(); ctx.arc(cx+ap.x*px,cy+ap.y*px,pulse,0,Math.PI*2); ctx.fill();
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

// Perturbation canvas — driven by window.PERTURB_DATA (computed server-side)
(function() {
  const cv  = document.getElementById('pert-canvas');
  const ctx = cv.getContext('2d');
  let W, H, DPR, mode = 'on';

  function resize() {
    const r = cv.parentElement.getBoundingClientRect();
    DPR = Math.max(1, window.devicePixelRatio || 1);
    W = r.width; H = r.height;
    cv.width = W * DPR; cv.height = H * DPR;
    cv.style.width = W + 'px'; cv.style.height = H + 'px';
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const pdata = window.PERTURB_DATA;
    const left = 80, right = W - 40, top = 24, bottom = H - 28;
    const chartW = right - left, chartH = bottom - top;

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.10)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(left, top); ctx.lineTo(left, bottom);
    ctx.moveTo(left, bottom); ctx.lineTo(right, bottom);
    ctx.stroke();

    // Year ticks — 2026 to 2068
    const tickYears = ['2026', '2036', '2047', '2058', '2068'];
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.font = '10px JetBrains Mono';
    tickYears.forEach((y, k) => {
      const x = left + (k / 4) * chartW;
      ctx.beginPath(); ctx.moveTo(x, bottom); ctx.lineTo(x, bottom + 4); ctx.stroke();
      ctx.fillText(y, x - 14, bottom + 16);
    });

    if (!pdata || !pdata.devKm || pdata.devKm.length === 0) {
      // Fallback: illustrative curve when physics data unavailable
      ctx.fillStyle = 'rgba(255,107,43,0.5)';
      ctx.font = '12px Space Grotesk';
      ctx.fillText('Perturbation data unavailable', left + 20, top + 40);
      return;
    }

    const devKm = pdata.devKm;
    const n     = devKm.length;
    const maxDev = Math.max(...devKm) * 1.12 || 1;

    // Y-axis label (top)
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.font = '9px JetBrains Mono';
    ctx.fillText('km', left - 26, top + 6);
    ctx.fillText('0', left - 14, bottom + 4);
    ctx.fillText(Math.round(maxDev / 1000) + 'k', left - 26, top + 14);

    function pathDev(fillAlpha, strokeColor) {
      ctx.beginPath();
      devKm.forEach((d, i) => {
        const x = left + (i / (n - 1)) * chartW;
        const y = bottom - (d / maxDev) * chartH;
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      });
      if (fillAlpha > 0) {
        const lastX = left + chartW;
        ctx.lineTo(lastX, bottom); ctx.lineTo(left, bottom); ctx.closePath();
        ctx.fillStyle = `rgba(255,107,43,${fillAlpha})`; ctx.fill();
        // re-draw stroke on top
        ctx.beginPath();
        devKm.forEach((d, i) => {
          const x = left + (i / (n - 1)) * chartW;
          const y = bottom - (d / maxDev) * chartH;
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
      }
      ctx.strokeStyle = strokeColor; ctx.lineWidth = 1.5;
      ctx.setLineDash([]); ctx.stroke();
    }

    if (mode === 'on') {
      // Show the perturbation divergence (N-body vs 2-body)
      pathDev(0.09, '#ff8a55');
      ctx.fillStyle = 'rgba(255,138,85,0.85)';
      ctx.font = '11px Space Grotesk';
      ctx.fillText('N-body (with Jupiter) divergence', left + 8, top + 14);
    } else if (mode === 'off') {
      // Reference flat line — Kepler-only has zero perturbation by definition
      ctx.beginPath(); ctx.moveTo(left, bottom - 8); ctx.lineTo(right, bottom - 8);
      ctx.strokeStyle = '#4f8fff'; ctx.lineWidth = 1.5; ctx.setLineDash([]); ctx.stroke();
      ctx.fillStyle = '#6fb4ff'; ctx.font = '11px Space Grotesk';
      ctx.fillText('Kepler-only (reference — no perturbation)', left + 8, bottom - 14);
      // Overlay faint divergence to show what's being ignored
      pathDev(0, 'rgba(255,107,43,0.20)');
    } else {
      // Difference — fill prominently
      pathDev(0.18, '#ff8a55');
      ctx.fillStyle = 'rgba(255,138,85,0.85)';
      ctx.font = '11px Space Grotesk';
      ctx.fillText('Cumulative perturbation', left + 8, top + 14);
    }

    // Final deviation label
    if (pdata.stats) {
      const fd = pdata.stats.finalDevKm.toLocaleString();
      const lx = right - 2;
      const ly = bottom - (devKm[devKm.length - 1] / maxDev) * chartH;
      ctx.fillStyle = 'rgba(255,138,85,0.9)';
      ctx.font = '10px JetBrains Mono';
      ctx.textAlign = 'right';
      ctx.fillText(`+${fd} km at 2068`, lx, Math.max(top + 12, ly - 6));
      ctx.textAlign = 'left';
    }
  }

  document.querySelectorAll('.pert-toggle button').forEach(b => b.addEventListener('click', () => {
    document.querySelectorAll('.pert-toggle button').forEach(x => x.classList.toggle('active', x === b));
    mode = b.dataset.mode; draw();
  }));

  resize(); draw();
  window.addEventListener('resize', () => { resize(); draw(); });
})();
</script>

