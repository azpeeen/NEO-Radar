<script>
// Catalog injected server-side from src/data/catalog.js (47 objects)
const NEOS = <%- JSON.stringify(neos.map(n => ({
  id:       n.id,
  name:     n.name,
  desig:    n.desig,
  risk:     n.riskLevel,
  label:    n.label,
  a:        n.a,
  e:        n.e,
  i:        n.i,
  om:       n.Omega,
  w:        n.omega,
  phase:    n.phase,
  nextLD:   n.missDist_ld,
  nextDate: n.nextDate,
  nextKm:   n.nextKm,
  vel:      n.velocity_kms,
}))) %>;

// Deep-link initial state
const _FOCUS_ID   = <%- JSON.stringify(focusId) %>;
const _FOCUS_DATE = <%- JSON.stringify(focusDate) %>;
const PLANETS = [
  { name:'Mercury', a:0.387, e:0.21,  phase:1.5, color:'#a8a8a8', r:1.6, inner:true  },
  { name:'Venus',   a:0.723, e:0.007, phase:4.2, color:'#e8b878', r:2.2, inner:true  },
  { name:'Earth',   a:1.000, e:0.017, phase:2.6, color:'#4f8fff', r:2.6, inner:false, glow:true  },
  { name:'Mars',    a:1.524, e:0.093, phase:0.8, color:'#ff8a55', r:2.0, inner:true  },
  { name:'Jupiter', a:5.204, e:0.048, phase:5.7, color:'#c79b6e', r:6.0, inner:false, glow:true  },
  { name:'Saturn',  a:9.583, e:0.054, phase:1.3, color:'#d4c79c', r:5.4, inner:false, ring:true  },
];
// Apply deep-link date if provided (?date=2029-04-13)
let _initSimTime = 0;
if (_FOCUS_DATE) {
  const epoch = new Date(Date.UTC(2026,4,27,12,0,0));
  const target = new Date(_FOCUS_DATE + 'T00:00:00Z');
  _initSimTime = Math.max(0, (target - epoch) / 86400000);
}

const state = {
  selectedId: (_FOCUS_ID && NEOS.find(n => n.id === _FOCUS_ID)) ? _FOCUS_ID : (NEOS[0] && NEOS[0].id),
  hoverId: null, filter: 'all', search: '', playing: true, speed: 1.0,
  daysPerSec: 12, simTime: _initSimTime,
  jupiter: true, saturn: true, uncertainty: true, trails: true, inner: false,
  pxPerAU: 80, zoom: 1.0, panX: 0, panY: 0,
};

function solveKepler(M, e) {
  let E = M + e*Math.sin(M);
  for (let k=0; k<20; k++) { const dE=(E-e*Math.sin(E)-M)/(1-e*Math.cos(E)); E-=dE; if(Math.abs(dE)<1e-10)break; }
  return E;
}
function orbitPos(o, t) {
  const period=Math.pow(o.a,1.5), M=((t/365.25)/period)*2*Math.PI+(o.phase||0), E=solveKepler(M,o.e);
  const x=o.a*(Math.cos(E)-o.e), y=o.a*Math.sqrt(1-o.e*o.e)*Math.sin(E);
  const ang=((o.w||0)+(o.om||0))*Math.PI/180;
  return { x:x*Math.cos(ang)-y*Math.sin(ang), y:x*Math.sin(ang)+y*Math.cos(ang) };
}

const cv=document.getElementById('radar-canvas'), ctx=cv.getContext('2d');
let W=0, H=0, DPR=1;
function resize() {
  const r=cv.parentElement.getBoundingClientRect(); DPR=Math.max(1,window.devicePixelRatio||1);
  W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR;
  cv.style.width=W+'px'; cv.style.height=H+'px'; ctx.setTransform(DPR,0,0,DPR,0,0);
}
resize(); window.addEventListener('resize', resize);
function ws(x,y){return{x:W/2+state.panX+x*state.pxPerAU*state.zoom, y:H/2+state.panY+y*state.pxPerAU*state.zoom};}

function drawOrbit(o, color, alpha=0.18) {
  ctx.beginPath();
  for(let k=0;k<=200;k++){const Mt=(k/200)*2*Math.PI+(o.phase||0),E=solveKepler(Mt,o.e),x=o.a*(Math.cos(E)-o.e),y=o.a*Math.sqrt(1-o.e*o.e)*Math.sin(E),ang=((o.w||0)+(o.om||0))*Math.PI/180,s=ws(x*Math.cos(ang)-y*Math.sin(ang),x*Math.sin(ang)+y*Math.cos(ang));k===0?ctx.moveTo(s.x,s.y):ctx.lineTo(s.x,s.y);}
  ctx.strokeStyle=color; ctx.globalAlpha=alpha; ctx.lineWidth=0.8; ctx.stroke(); ctx.globalAlpha=1;
}
function drawSun() {
  const s=ws(0,0), g=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,80);
  g.addColorStop(0,'rgba(255,220,160,0.8)'); g.addColorStop(0.4,'rgba(255,180,100,0.12)'); g.addColorStop(1,'rgba(255,180,100,0)');
  ctx.fillStyle=g; ctx.fillRect(s.x-100,s.y-100,200,200);
  ctx.fillStyle='#ffd87a'; ctx.beginPath(); ctx.arc(s.x,s.y,5,0,Math.PI*2); ctx.fill();
}
function drawPlanet(p, t) {
  const pos=orbitPos(p,t), s=ws(pos.x,pos.y);
  if(p.glow){const g=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,30);g.addColorStop(0,p.color);g.addColorStop(0.3,p.color+'66');g.addColorStop(1,p.color+'00');ctx.fillStyle=g;ctx.fillRect(s.x-40,s.y-40,80,80);}
  ctx.fillStyle=p.color; ctx.beginPath(); ctx.arc(s.x,s.y,p.r,0,Math.PI*2); ctx.fill();
  if(p.ring){ctx.strokeStyle='rgba(212,199,156,0.5)';ctx.lineWidth=1;ctx.beginPath();ctx.ellipse(s.x,s.y,p.r*2.2,p.r*0.6,0.3,0,Math.PI*2);ctx.stroke();}
  ctx.fillStyle='rgba(200,210,230,0.65)'; ctx.font='10px JetBrains Mono'; ctx.fillText(p.name,s.x+p.r+6,s.y+3);
}
function drawUncertaintyCone(o, t) {
  if(!state.uncertainty)return;
  const pts=[];
  for(let k=0;k<=100;k++){const dt=(k-50)*8,tt=t+dt,period=Math.pow(o.a,1.5),Mt=((tt/365.25)/period)*2*Math.PI+(o.phase||0),E=solveKepler(Mt,o.e),x=o.a*(Math.cos(E)-o.e),y=o.a*Math.sqrt(1-o.e*o.e)*Math.sin(E),ang=((o.w||0)+(o.om||0))*Math.PI/180,wx=x*Math.cos(ang)-y*Math.sin(ang),wy=x*Math.sin(ang)+y*Math.cos(ang),jup=orbitPos(PLANETS[4],tt),dJ=Math.hypot(wx-jup.x,wy-jup.y);pts.push({x:wx,y:wy,w:0.005+0.05/(dJ*dJ+0.4)});}
  const upper=[],lower=[];
  for(let k=0;k<pts.length;k++){const p=pts[k],next=pts[Math.min(k+1,pts.length-1)],dx=next.x-p.x,dy=next.y-p.y,len=Math.hypot(dx,dy)||1e-9,nx=-dy/len,ny=dx/len;upper.push(ws(p.x+nx*p.w,p.y+ny*p.w));lower.push(ws(p.x-nx*p.w,p.y-ny*p.w));}
  ctx.beginPath(); ctx.moveTo(upper[0].x,upper[0].y);
  for(const p of upper)ctx.lineTo(p.x,p.y);
  for(let k=lower.length-1;k>=0;k--)ctx.lineTo(lower[k].x,lower[k].y);
  ctx.closePath();
  const isCaution=(o.risk==='caution'||o.risk==='hazard');
  ctx.fillStyle=isCaution?'rgba(255,107,43,0.10)':'rgba(26,108,246,0.08)'; ctx.fill();
  ctx.strokeStyle=isCaution?'rgba(255,107,43,0.25)':'rgba(26,108,246,0.18)'; ctx.lineWidth=0.6; ctx.stroke();
}
function drawNEO(n, t) {
  const pos=orbitPos(n,t), s=ws(pos.x,pos.y), isSel=state.selectedId===n.id, isHov=state.hoverId===n.id;
  let color,alpha;
  if(n.risk==='hazard'){color='rgba(255,107,43,1)';alpha=isSel?0.7:0.35;}
  else if(n.risk==='caution'){color='rgba(255,180,80,1)';alpha=isSel?0.6:0.3;}
  else if(n.risk==='monitor'){color='rgba(111,180,255,1)';alpha=isSel?0.55:0.25;}
  else{color='rgba(170,180,210,1)';alpha=isSel?0.45:0.18;}
  drawOrbit(n,color,alpha);
  if(isSel)drawUncertaintyCone(n,t);
  if(isSel){const pulse=4+Math.sin(t*0.5)*1.2;ctx.beginPath();ctx.arc(s.x,s.y,pulse+6,0,Math.PI*2);ctx.fillStyle=(n.risk==='caution'||n.risk==='hazard')?'rgba(255,107,43,0.18)':'rgba(26,108,246,0.22)';ctx.fill();}
  ctx.beginPath(); ctx.arc(s.x,s.y,isSel?4:(isHov?3.5:2.4),0,Math.PI*2);
  ctx.fillStyle=(n.risk==='hazard'||n.risk==='caution')?'#ff8a55':(n.risk==='monitor'?'#6fb4ff':'#cfd6ea'); ctx.fill();
  if(isSel||isHov){ctx.fillStyle='rgba(240,244,255,0.85)';ctx.font='11px Space Grotesk';ctx.fillText(n.name,s.x+8,s.y-6);}
}
function drawJupiterVector(t) {
  if(!state.jupiter)return;
  const sel=NEOS.find(n=>n.id===state.selectedId); if(!sel)return;
  const ap=orbitPos(sel,t),jp=orbitPos(PLANETS[4],t),dx=jp.x-ap.x,dy=jp.y-ap.y,d=Math.hypot(dx,dy);
  if(d>6)return;
  const a=ws(ap.x,ap.y),b=ws(ap.x+dx*0.06,ap.y+dy*0.06);
  ctx.strokeStyle='rgba(255,107,43,0.75)'; ctx.lineWidth=1.2; ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke();
  const ang=Math.atan2(b.y-a.y,b.x-a.x);
  ctx.beginPath(); ctx.moveTo(b.x,b.y); ctx.lineTo(b.x-6*Math.cos(ang-0.4),b.y-6*Math.sin(ang-0.4)); ctx.moveTo(b.x,b.y); ctx.lineTo(b.x-6*Math.cos(ang+0.4),b.y-6*Math.sin(ang+0.4)); ctx.stroke();
  ctx.fillStyle='rgba(255,107,43,0.9)'; ctx.font='10px JetBrains Mono'; ctx.fillText('+Δv',b.x+4,b.y-4);
}

const _J2000_RAF = Date.UTC(2000, 0, 1, 12, 0, 0);
const _T_SIM_RAF = _J2000_RAF + 9643 * 86400000; // sim epoch = 2026-05-27

let last=performance.now();
function tick(now) {
  const dt=Math.min(0.1,(now-last)/1000); last=now;
  if(state.playing) {
    // If simTime is within 1 minute of real time, pin it directly to Date.now()
    // so live mode has zero accumulation error and zero drift.
    const realNow = (Date.now() - _T_SIM_RAF) / 86400000;
    if (Math.abs(state.simTime - realNow) < 1 / (24 * 60)) {
      state.simTime = realNow;
    } else {
      state.simTime += dt * state.daysPerSec * state.speed;
    }
  }
  ctx.clearRect(0,0,W,H);
  for(const p of PLANETS){if(p.inner&&!state.inner)continue; drawOrbit(p,'rgba(255,255,255,1)',0.07);}
  drawSun();
  for(const n of NEOS) drawNEO(n,state.simTime);
  for(const p of PLANETS){if(p.inner&&!state.inner)continue; drawPlanet(p,state.simTime);}
  drawJupiterVector(state.simTime);
  updateClock();
  requestAnimationFrame(tick);
}
requestAnimationFrame(tick);

// Display timezone — physics always runs in UTC/J2000 internally
var _selectedTz = (function () {
  try {
    var known = ['UTC','America/Sao_Paulo','America/New_York','America/Los_Angeles',
                 'Europe/London','Europe/Paris','Asia/Tokyo','Asia/Shanghai','Australia/Sydney'];
    var btz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    return known.includes(btz) ? btz : 'UTC';
  } catch (e) { return 'UTC'; }
}());

function updateClock() {
  var epoch = new Date(Date.UTC(2026, 4, 27, 12, 0, 0));
  var d     = new Date(epoch.getTime() + state.simTime * 86400000);
  var fmt   = new Intl.DateTimeFormat('en-CA', {
    timeZone: _selectedTz,
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', hour12: false,
  });
  var p = Object.fromEntries(fmt.formatToParts(d).map(function (x) { return [x.type, x.value]; }));
  var tzLabel = _selectedTz === 'UTC' ? 'UTC' : _selectedTz.split('/').pop().replace(/_/g, ' ');
  document.getElementById('sim-clock-val').textContent =
    p.year + '·' + p.month + '·' + p.day + ' ' + p.hour + ':' + p.minute + ' ' + tzLabel;
}
function renderList() {
  const q=state.search.toLowerCase().trim();
  const filtered=NEOS.filter(n=>{
    if(state.filter!=='all'&&n.risk!==state.filter)return false;
    if(q&&!(n.name.toLowerCase().includes(q)||n.desig.toLowerCase().includes(q)))return false;
    return true;
  }).sort((a,b)=>a.nextLD-b.nextLD);
  document.getElementById('result-count').textContent=`${filtered.length} result${filtered.length===1?'':'s'}`;
  document.getElementById('neo-list').innerHTML=filtered.map(n=>`
    <div class="neo-item r-${n.risk}${state.selectedId===n.id?' selected':''}" data-id="${n.id}">
      <div class="name"><span class="risk-dot"></span>${n.name}</div>
      <div class="desig">${n.desig}</div>
      <div class="ld">${n.nextLD<1?n.nextLD.toFixed(2):n.nextLD.toFixed(1)}<small>LUNAR DIST</small></div>
    </div>`).join('');
  document.querySelectorAll('.neo-item').forEach(el=>el.addEventListener('click',()=>{state.selectedId=el.dataset.id;renderList();renderSelected();}));
}
function renderSelected() {
  const n=NEOS.find(x=>x.id===state.selectedId); if(!n)return;
  document.getElementById('sel-name').textContent=n.name;
  document.getElementById('sel-desig').textContent=`${n.desig} · NEA`;
  const re=document.getElementById('sel-risk'); re.className=`risk ${n.risk}`; re.textContent=n.label;
  document.getElementById('sel-figure').innerHTML=`${n.nextKm}<small>km</small>`;
  document.getElementById('sel-sub').textContent=`${n.nextDate} — ${n.nextLD} LD — Δv ${n.vel} km/s`;
  document.getElementById('el-a').innerHTML=`${n.a.toFixed(3)} <small>AU</small>`;
  document.getElementById('el-e').textContent=n.e.toFixed(3);
  document.getElementById('el-i').innerHTML=`${n.i.toFixed(2)}<small>°</small>`;
  document.getElementById('el-o').textContent=`${n.om.toFixed(0)}·${n.w.toFixed(0)}`;
}
document.getElementById('search-input').addEventListener('input',e=>{state.search=e.target.value;renderList();});
document.querySelectorAll('#filter-chips .chip').forEach(c=>c.addEventListener('click',()=>{state.filter=c.dataset.risk;document.querySelectorAll('#filter-chips .chip').forEach(x=>x.classList.toggle('active',x===c));renderList();}));
function toggle(id,key,cb){document.getElementById(id).addEventListener('click',function(){state[key]=!state[key];this.classList.toggle('on',state[key]);if(cb)cb();});}
toggle('tg-jup','jupiter',()=>document.getElementById('pert-val').textContent=['Sun',state.saturn&&'Saturn',state.jupiter&&'Jupiter'].filter(Boolean).join(' · '));
toggle('tg-sat','saturn',()=>document.getElementById('pert-val').textContent=['Sun',state.saturn&&'Saturn',state.jupiter&&'Jupiter'].filter(Boolean).join(' · '));
toggle('tg-unc','uncertainty'); toggle('tg-trail','trails'); toggle('tg-inner','inner');
const dtSlider=document.getElementById('dt-slider');
dtSlider.addEventListener('input',()=>{const v=parseFloat(dtSlider.value),lo=Math.log(0.001),hi=Math.log(365),d=Math.exp(lo+(v/100)*(hi-lo));state.daysPerSec=Math.max(0.1,d*10);document.getElementById('dt-val').textContent=`Δt = ${d<1?d.toFixed(3):d<10?d.toFixed(2):d.toFixed(0)} d`;dtSlider.style.setProperty('--p',v+'%');});
dtSlider.style.setProperty('--p',dtSlider.value+'%');
const playIc=document.getElementById('play-ic');
document.getElementById('btn-play').addEventListener('click',()=>{state.playing=!state.playing;playIc.innerHTML=state.playing?'<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>':'<path d="M8 5v14l11-7z"/>';});
document.getElementById('btn-fwd').addEventListener('click',()=>{state.speed=Math.min(8,state.speed*2);document.getElementById('speed-val').textContent='×'+state.speed.toFixed(1);});
document.getElementById('btn-rew').addEventListener('click',()=>{state.speed=Math.max(0.125,state.speed/2);document.getElementById('speed-val').textContent='×'+state.speed.toFixed(1);});
cv.addEventListener('mousemove',e=>{const r=cv.getBoundingClientRect(),x=e.clientX-r.left,y=e.clientY-r.top;let best=null,bestD=22;for(const n of NEOS){const p=orbitPos(n,state.simTime),s=ws(p.x,p.y),d=Math.hypot(s.x-x,s.y-y);if(d<bestD){bestD=d;best=n;}}const tt=document.getElementById('tooltip');if(best){state.hoverId=best.id;tt.style.left=x+'px';tt.style.top=y+'px';tt.classList.add('show');document.getElementById('tt-name').textContent=best.name;document.getElementById('tt-desig').textContent=best.desig;document.getElementById('tt-d').textContent=`${best.nextLD} LD · ${best.nextKm} km`;document.getElementById('tt-v').textContent=`${best.vel} km/s`;cv.style.cursor='pointer';}else{state.hoverId=null;tt.classList.remove('show');cv.style.cursor='crosshair';}});
cv.addEventListener('mouseleave',()=>{state.hoverId=null;document.getElementById('tooltip').classList.remove('show');});
cv.addEventListener('click',()=>{if(state.hoverId){state.selectedId=state.hoverId;renderList();renderSelected();}});
cv.addEventListener('wheel',e=>{e.preventDefault();state.zoom=Math.max(0.3,Math.min(3,state.zoom*(1-Math.sign(e.deltaY)*0.12)));document.getElementById('scale-val').textContent=`1 AU = ${(state.pxPerAU*state.zoom).toFixed(0)} px`;},{passive:false});
document.addEventListener('keydown',e=>{if(e.target.tagName==='INPUT')return;if(e.key==='/'){{e.preventDefault();document.getElementById('search-input').focus();}}if(e.key===' '){e.preventDefault();document.getElementById('btn-play').click();}});

// ─── Return to Live button ─────────────────────────────────────────────────
// J2000.0 = 2000-Jan-01 12:00:00 UTC
const _J2000_MS = Date.UTC(2000, 0, 1, 12, 0, 0);
// Sim epoch offset: simTime=0 corresponds to 2026-05-27 12:00 (9643 days from J2000)
const _T_SIM_MS = _J2000_MS + 9643 * 86400000;

function _nowSimDays() {
  // Current real time expressed as days from T_SIM (the sim epoch)
  return (Date.now() - _T_SIM_MS) / 86400000;
}

// Threshold: within 1 real minute of "now" = 1/(24*60) days
const _LIVE_THRESH_DAYS = 1 / (24 * 60);

function _updateLiveBtn() {
  const isLive = state.playing &&
                 Math.abs(state.simTime - _nowSimDays()) < _LIVE_THRESH_DAYS;

  ['btn-live', 'fab-live'].forEach(function (id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle('is-live', isLive);
    const label = el.querySelector('#live-label, .fab-label');
    if (label) label.textContent = isLive ? '● LIVE' : '→ LIVE';
    const dot = el.querySelector('#live-dot, .fab-dot');
    if (dot) dot.style.animationPlayState = isLive ? 'running' : 'paused';
  });
}

function _handleLive() {
  const nowDays = _nowSimDays();
  // Require state.playing so that pausing immediately ends "live" —
  // prevents the 60-second window where re-clicking was a no-op.
  const isCurrentlyLive = state.playing &&
                          Math.abs(state.simTime - nowDays) < _LIVE_THRESH_DAYS;

  if (isCurrentlyLive) {
    // DEACTIVATE — reload to clean state
    window.location.reload();
  } else {
    // ACTIVATE — snap to real time and resume
    state.simTime    = nowDays;
    state.playing    = true;
    state.speed      = 1.0;
    state.daysPerSec = 1.0;
    document.getElementById('play-ic').innerHTML = '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>';
    document.getElementById('speed-val').textContent = '×1.0';
  }

  // sync both buttons to the NEW state
  const live = !isCurrentlyLive;
  ['btn-live', 'fab-live'].forEach(function (id) {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('is-live', live);
  });
  document.getElementById('live-label').textContent = live ? '● LIVE' : '→ LIVE';
}
// Both LIVE buttons (desktop topbar + mobile FAB) share the exact same handler
[document.getElementById('btn-live'), document.getElementById('fab-live')]
  .filter(Boolean)
  .forEach(function (btn) {
    btn.addEventListener('click', _handleLive);
    btn.addEventListener('touchend', function (e) {
      e.preventDefault(); // suppress ghost click after touchend
      _handleLive();
    });
  });

// Poll every second: update button state + optionally sync clock display
setInterval(() => { _updateLiveBtn(); }, 1000);
_updateLiveBtn();

// ─── Bottom-sheet (mobile) ────────────────────────────────────
const _sidebar     = document.getElementById('radar-sidebar');
const _sheetHandle = document.getElementById('sheet-handle');

if (_sheetHandle && _sidebar) {
  var _dragStartY  = null;
  var _dragDeltaY  = 0;
  var CLOSE_THRESH = 80; // px of downward drag required to close

  _sheetHandle.addEventListener('touchstart', function (e) {
    _dragStartY = e.touches[0].clientY;
    _dragDeltaY = 0;
    // Remove CSS transition so the sheet tracks the finger in real time
    _sidebar.style.transition = 'none';
  }, { passive: true });

  _sheetHandle.addEventListener('touchmove', function (e) {
    if (_dragStartY === null) return;
    _dragDeltaY = e.touches[0].clientY - _dragStartY;
    // Only translate downward, and only when the sheet is currently open
    if (_dragDeltaY > 0 && _sidebar.classList.contains('sheet-open')) {
      _sidebar.style.transform = 'translateY(' + _dragDeltaY + 'px)';
      e.preventDefault();
    }
  }, { passive: false });

  _sheetHandle.addEventListener('touchend', function (e) {
    e.preventDefault(); // suppress ghost click
    // Re-enable smooth CSS transition for the snap animation
    _sidebar.style.transition = '';
    _sidebar.style.transform  = ''; // hand control back to CSS class

    if (_sidebar.classList.contains('sheet-open')) {
      // Drag down past threshold OR simple tap → close
      if (_dragDeltaY > CLOSE_THRESH || Math.abs(_dragDeltaY) < 10) {
        _sidebar.classList.remove('sheet-open');
      }
      // else: partial drag — spring back to open (CSS transition handles it)
    } else {
      // Sheet is collapsed: tap → open
      if (Math.abs(_dragDeltaY) < 10) {
        _sidebar.classList.add('sheet-open');
      }
    }

    _dragStartY = null;
    _dragDeltaY = 0;
  }, { passive: false });

  // Desktop fallback: mouse click toggles the sheet
  _sheetHandle.addEventListener('click', function () {
    _sidebar.classList.toggle('sheet-open');
  });
}
// Update the collapsed summary whenever selection changes
function _updateSheetSummary(n) {
  const nameEl = document.getElementById('sheet-name');
  const riskEl = document.getElementById('sheet-risk');
  if (nameEl) nameEl.textContent = n.name;
  if (riskEl) { riskEl.className = 'risk ' + n.risk; riskEl.textContent = n.label; }
}

// ─── Touch controls ───────────────────────────────────────────
(function () {
  let pinchDist = null;
  let panStart  = null;

  cv.addEventListener('touchstart', function (e) {
    if (e.touches.length === 2) {
      pinchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      panStart = null;
      e.preventDefault();
    } else if (e.touches.length === 1) {
      panStart  = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      pinchDist = null;
    }
  }, { passive: false });

  cv.addEventListener('touchmove', function (e) {
    e.preventDefault();
    if (e.touches.length === 2 && pinchDist !== null) {
      var d = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      state.zoom = Math.max(0.3, Math.min(3, state.zoom * (d / pinchDist)));
      pinchDist  = d;
      document.getElementById('scale-val').textContent =
        '1 AU = ' + (state.pxPerAU * state.zoom).toFixed(0) + ' px';
    } else if (e.touches.length === 1 && panStart) {
      state.panX += e.touches[0].clientX - panStart.x;
      state.panY += e.touches[0].clientY - panStart.y;
      panStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }
  }, { passive: false });

  cv.addEventListener('touchend', function (e) {
    if (e.touches.length < 2) pinchDist = null;
    if (e.touches.length === 0) panStart = null;
  });
})();

// Wrap renderSelected so mobile sheet summary stays in sync
renderSelected = (function (orig) {
  return function () {
    orig();
    var n = NEOS.find(function (x) { return x.id === state.selectedId; });
    if (n) _updateSheetSummary(n);
  };
}(renderSelected));

renderList(); renderSelected();

// Custom timezone dropdowns — desktop + mobile stay in sync
(function () {
  var TZLABELS = {
    'UTC':                 'UTC',
    'America/Sao_Paulo':   'BRT (Brasília)',
    'America/New_York':    'EST (New York)',
    'America/Los_Angeles': 'PST (Los Angeles)',
    'Europe/London':       'GMT (London)',
    'Europe/Paris':        'CET (Paris)',
    'Asia/Tokyo':          'JST (Tokyo)',
    'Asia/Shanghai':       'CST (Shanghai)',
    'Australia/Sydney':    'AEST (Sydney)',
  };

  // Collect both dropdown instances (desktop + mobile)
  var instances = [
    { trigger: document.getElementById('tz-trigger'),
      menu:    document.getElementById('tz-menu'),
      current: document.getElementById('tz-current') },
    { trigger: document.getElementById('tz-trigger-mobile'),
      menu:    document.getElementById('tz-menu-mobile'),
      current: document.getElementById('tz-current-mobile') },
  ].filter(function (d) { return d.trigger && d.menu && d.current; });

  function closeAll() {
    instances.forEach(function (d) { d.menu.classList.remove('open'); });
  }

  function applyTz(tz) {
    _selectedTz = tz;
    instances.forEach(function (d) {
      d.current.textContent = TZLABELS[tz] || tz;
      d.menu.querySelectorAll('li').forEach(function (li) {
        li.classList.toggle('active', li.dataset.tz === tz);
      });
    });
    updateClock();
  }

  instances.forEach(function (d) {
    // Toggle open/close on trigger click
    d.trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      var wasOpen = d.menu.classList.contains('open');
      closeAll();
      if (!wasOpen) d.menu.classList.add('open');
    });
    // Select timezone on option click
    d.menu.querySelectorAll('li').forEach(function (li) {
      li.addEventListener('click', function () {
        applyTz(li.dataset.tz);
        closeAll();
      });
    });
  });

  // Close on any outside click
  document.addEventListener('click', closeAll);

  // Initialize both to detected timezone
  applyTz(_selectedTz);
}());
</script>

