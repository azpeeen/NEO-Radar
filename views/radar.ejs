<%- include('partials/head', { title: 'NEO Radar — Orbital Visualizer' }) %>

<style>
  html, body { height: 100%; overflow: hidden; }
  body { background: #050508; }
  .radar-shell { display: grid; grid-template-rows: 60px 1fr; grid-template-columns: 1fr 400px; grid-template-areas: "topbar topbar" "canvas sidebar"; height: 100vh; width: 100vw; }
  .topbar { grid-area: topbar; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; border-bottom: 1px solid var(--line); background: rgba(5,5,8,0.85); backdrop-filter: blur(10px); z-index: 5; }
  .topbar .left { display: flex; align-items: center; gap: 28px; }
  .topbar .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ink); }
  .topbar .brand .mark { width: 24px; height: 24px; }
  .topbar .brand .name { font-family: var(--font-display); font-weight: 500; font-size: 15px; letter-spacing: -0.01em; }
  .topbar .links { display: flex; gap: 20px; }
  .topbar .links a { font-size: 12.5px; color: var(--ink-3); text-decoration: none; transition: color 160ms; }
  .topbar .links a:hover { color: var(--ink); }
  .topbar .links a.active { color: var(--ink); }
  .sim-clock { display: flex; align-items: center; gap: 14px; padding: 8px 16px; border: 1px solid var(--line); border-radius: 8px; background: rgba(255,255,255,0.02); }
  .sim-clock .lbl { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-4); }
  .sim-clock .val { font-family: var(--font-mono); font-size: 13px; color: var(--ink); font-variant-numeric: tabular-nums; }
  .topbar .right { display: flex; align-items: center; gap: 16px; }
  .canvas-area { grid-area: canvas; position: relative; overflow: hidden; background: radial-gradient(1200px 800px at 40% 40%, rgba(26,108,246,0.06), transparent 60%), #050508; }
  .canvas-area canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .stars { position: absolute; inset: 0; background-image: radial-gradient(0.7px 0.7px at 20% 30%, rgba(255,255,255,0.6), transparent 50%), radial-gradient(1px 1px at 65% 70%, rgba(255,255,255,0.4), transparent 50%), radial-gradient(0.7px 0.7px at 80% 20%, rgba(255,255,255,0.7), transparent 50%), radial-gradient(0.7px 0.7px at 35% 85%, rgba(255,255,255,0.3), transparent 50%), radial-gradient(1.2px 1.2px at 50% 50%, rgba(200,220,255,0.5), transparent 50%); background-size: 700px 500px; opacity: 0.6; animation: drift 360s linear infinite; pointer-events: none; }
  .canvas-overlay { position: absolute; pointer-events: none; z-index: 4; }
  .corner-overlay { padding: 14px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-4); }
  .corner-overlay .v { color: var(--ink-2); }
  .legend { position: absolute; bottom: 16px; left: 16px; z-index: 4; display: flex; gap: 14px; padding: 10px 14px; background: rgba(8,10,18,0.6); border: 1px solid var(--line); border-radius: 8px; backdrop-filter: blur(8px); }
  .legend .item { display: flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .legend .dot { width: 8px; height: 8px; border-radius: 50%; }
  .scale-bar { position: absolute; bottom: 16px; right: 16px; z-index: 4; padding: 8px 12px; background: rgba(8,10,18,0.6); border: 1px solid var(--line); border-radius: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--ink-3); backdrop-filter: blur(8px); }
  .scale-bar .bar { display: inline-block; width: 80px; height: 2px; background: linear-gradient(90deg, transparent, var(--ink-2), transparent); vertical-align: middle; margin: 0 8px; }
  .obj-tooltip { position: absolute; z-index: 6; pointer-events: none; padding: 10px 12px; background: rgba(8,10,18,0.92); border: 1px solid var(--line-strong); border-radius: 8px; backdrop-filter: blur(10px); font-size: 12px; min-width: 180px; transform: translate(12px, 12px); opacity: 0; transition: opacity 120ms; }
  .obj-tooltip.show { opacity: 1; }
  .obj-tooltip .name { font-family: var(--font-display); font-weight: 500; font-size: 14px; margin-bottom: 2px; }
  .obj-tooltip .desig { font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); margin-bottom: 8px; }
  .obj-tooltip .kv { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; margin: 2px 0; }
  .obj-tooltip .kv .k { color: var(--ink-3); } .obj-tooltip .kv .v { color: var(--ink); }
  .sidebar { grid-area: sidebar; border-left: 1px solid var(--line); background: rgba(8,9,16,0.7); backdrop-filter: blur(10px); overflow-y: auto; z-index: 5; }
  .sidebar::-webkit-scrollbar { width: 6px; } .sidebar::-webkit-scrollbar-track { background: transparent; } .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); border-radius: 3px; }
  .sb-section { padding: 20px; border-bottom: 1px solid var(--line); }
  .sb-h { display: flex; align-items: center; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 14px; }
  .search { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border: 1px solid var(--line); border-radius: 8px; background: rgba(255,255,255,0.02); }
  .search input { flex: 1; background: none; border: none; outline: none; color: var(--ink); font-family: var(--font-body); font-size: 13px; }
  .search input::placeholder { color: var(--ink-4); }
  .filters { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
  .chip { display: inline-flex; align-items: center; gap: 6px; padding: 5px 10px; border-radius: 999px; border: 1px solid var(--line); background: transparent; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); cursor: pointer; transition: all 160ms; }
  .chip:hover { color: var(--ink); border-color: var(--line-strong); }
  .chip.active { color: var(--ink); border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.04); }
  .neo-list { display: flex; flex-direction: column; gap: 4px; }
  .neo-item { display: grid; grid-template-columns: 1fr auto; gap: 4px 12px; padding: 10px 12px; border: 1px solid transparent; border-radius: 8px; cursor: pointer; transition: all 140ms; }
  .neo-item:hover { background: rgba(255,255,255,0.025); border-color: var(--line); }
  .neo-item.selected { background: rgba(26,108,246,0.08); border-color: rgba(26,108,246,0.4); }
  .neo-item .name { font-family: var(--font-display); font-weight: 500; font-size: 14px; letter-spacing: -0.01em; }
  .neo-item .desig { grid-column: 1; font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); }
  .neo-item .ld { grid-row: 1 / 3; grid-column: 2; align-self: center; text-align: right; font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); font-variant-numeric: tabular-nums; }
  .neo-item .ld small { display: block; color: var(--ink-4); font-size: 9px; letter-spacing: 0.1em; margin-top: 1px; }
  .neo-item .risk-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; margin-right: 8px; }
  .neo-item.r-safe    .risk-dot { background: var(--green); }
  .neo-item.r-monitor .risk-dot { background: #6fb4ff; }
  .neo-item.r-caution .risk-dot { background: var(--yellow); }
  .neo-item.r-hazard  .risk-dot { background: var(--amber); box-shadow: 0 0 6px var(--amber-glow); }
  .sel-card .title-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 14px; margin-bottom: 16px; }
  .sel-card .title-row .name { font-family: var(--font-display); font-weight: 500; font-size: 22px; letter-spacing: -0.02em; line-height: 1.1; }
  .sel-card .title-row .desig { font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); margin-top: 4px; letter-spacing: 0.06em; }
  .sel-card .elements { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; margin-bottom: 14px; }
  .sel-card .elements .cell { padding: 10px 12px; background: rgba(8,10,18,0.6); }
  .sel-card .elements .k { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 4px; }
  .sel-card .elements .v { font-family: var(--font-mono); font-size: 13px; color: var(--ink); font-variant-numeric: tabular-nums; }
  .sel-card .elements .v small { color: var(--ink-3); font-size: 10px; margin-left: 2px; }
  .sel-card .approach { padding: 14px; border-radius: 8px; background: rgba(26,108,246,0.06); border: 1px solid rgba(26,108,246,0.2); margin-bottom: 14px; }
  .sel-card .approach .top { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cobalt-soft); margin-bottom: 8px; }
  .sel-card .approach .figure { font-family: var(--font-display); font-size: 34px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.05; font-variant-numeric: tabular-nums; }
  .sel-card .approach .figure small { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); font-weight: 400; margin-left: 4px; }
  .sel-card .approach .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); margin-top: 6px; }
  .sel-card .actions { display: flex; gap: 8px; }
  .sel-card .actions a { flex: 1; display: inline-flex; align-items: center; justify-content: center; height: 36px; padding: 0 12px; border-radius: 6px; border: 1px solid var(--line); background: rgba(255,255,255,0.02); color: var(--ink-2); text-decoration: none; font-size: 12px; transition: all 160ms; }
  .sel-card .actions a:hover { color: var(--ink); border-color: var(--line-strong); background: rgba(255,255,255,0.04); }
  .control { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-top: 1px solid var(--line); }
  .control:first-child { border-top: none; padding-top: 0; }
  .control .label { display: flex; flex-direction: column; gap: 2px; }
  .control .label .t { font-size: 13px; color: var(--ink); }
  .control .label .d { font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); letter-spacing: 0.08em; }
  .toggle { width: 36px; height: 20px; border-radius: 999px; background: rgba(255,255,255,0.08); position: relative; cursor: pointer; transition: background 200ms; border: 1px solid var(--line); }
  .toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; border-radius: 50%; background: var(--ink-3); transition: all 200ms; }
  .toggle.on { background: var(--cobalt); border-color: var(--cobalt); }
  .toggle.on::after { left: 18px; background: white; }
  .slider-row { padding: 14px 0; border-top: 1px solid var(--line); }
  .slider-row .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .slider-row .top .t { font-size: 13px; }
  .slider-row .top .v { font-family: var(--font-mono); font-size: 11px; color: var(--cobalt-soft); font-variant-numeric: tabular-nums; }
  .slider-row input[type=range] { width: 100%; -webkit-appearance: none; appearance: none; height: 4px; background: linear-gradient(90deg, var(--cobalt) 0%, var(--cobalt) var(--p, 50%), rgba(255,255,255,0.08) var(--p, 50%)); border-radius: 2px; outline: none; }
  .slider-row input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 14px; height: 14px; border-radius: 50%; background: white; border: 2px solid var(--cobalt); cursor: pointer; box-shadow: 0 0 8px var(--cobalt-glow); }
  .slider-row .ticks { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 9px; color: var(--ink-4); letter-spacing: 0.06em; margin-top: 6px; }
  .playback { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: rgba(255,255,255,0.02); border: 1px solid var(--line); border-radius: 8px; margin-bottom: 12px; }
  .playback button { background: transparent; border: 1px solid var(--line); color: var(--ink-2); width: 30px; height: 30px; border-radius: 6px; cursor: pointer; display: grid; place-items: center; transition: all 160ms; }
  .playback button:hover { color: var(--ink); border-color: var(--line-strong); }
  .playback .speed { flex: 1; text-align: right; font-family: var(--font-mono); font-size: 11px; color: var(--cobalt-soft); font-variant-numeric: tabular-nums; }
  @keyframes pulse-live { 0%,100%{opacity:1;} 50%{opacity:0.2;} }
  .btn-live { display:inline-flex; align-items:center; gap:7px; padding:7px 14px; border:1px solid var(--line); border-radius:8px; background:rgba(255,255,255,0.02); font-family:var(--font-mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); cursor:pointer; transition:all 160ms; white-space:nowrap; flex-shrink:0; min-height:44px; min-width:44px; touch-action:manipulation; -webkit-tap-highlight-color:transparent; }
  .btn-live:hover { color:var(--ink); border-color:var(--line-strong); background:rgba(255,255,255,0.04); }
  .btn-live.is-live { color:var(--cobalt-soft); border-color:rgba(26,108,246,0.35); }
  .btn-live .live-dot { width:6px; height:6px; border-radius:50%; background:var(--cobalt-soft); flex-shrink:0; }
  .btn-live.is-live .live-dot { animation:pulse-live 1.4s ease-in-out infinite; }

  /* ── Tablet ────────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .radar-shell { grid-template-columns: 1fr; grid-template-rows: 60px 60vh 1fr; grid-template-areas: "topbar" "canvas" "sidebar"; }
    .sidebar { border-left: none; border-top: 1px solid var(--line); }
  }

  /* ── Mobile: canvas full screen, sidebar = bottom sheet ────── */
  @media (max-width: 767px) {
    .radar-shell {
      grid-template-columns: 1fr;
      grid-template-rows: 48px 1fr;
      grid-template-areas: "topbar" "canvas";
      height: 100dvh;
    }
    .topbar { height: 48px; padding: 0 12px; gap: 10px; }
    .topbar .left { gap: 12px; }
    .topbar .brand .name { font-size: 13px; }
    .topbar .links { display: none; }
    .sim-clock { padding: 5px 8px; gap: 6px; flex-shrink: 1; min-width: 0; overflow: hidden; }
    .sim-clock .lbl { display: none; }
    .sim-clock .val { font-size: 10.5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .btn-live { display: none; } /* replaced by FAB on mobile */

    /* Bottom sheet */
    .sidebar {
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 20;
      border-left: none;
      border-top: 1px solid var(--line);
      border-radius: 16px 16px 0 0;
      height: auto;
      max-height: 72vh;
      overflow: hidden;
      transform: translateY(calc(100% - 56px));
      transition: transform 340ms cubic-bezier(0.32, 0.72, 0, 1);
      will-change: transform;
      /* Home indicator clearance */
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    .sidebar.sheet-open {
      transform: translateY(0);
      overflow-y: auto;
    }

    /* Handle bar */
    .sheet-handle {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
      height: 56px;
      padding: 0 16px;
      cursor: pointer;
      background: rgba(8,9,16,0.97);
      border-radius: 16px 16px 0 0;
      flex-shrink: 0;
      position: sticky; top: 0; z-index: 1;
      user-select: none; -webkit-user-select: none;
      border-bottom: 1px solid var(--line);
      min-height: 44px;
    }
    .sheet-handle-pip {
      position: absolute;
      top: 10px; left: 50%; transform: translateX(-50%);
      width: 32px; height: 4px;
      border-radius: 2px;
      background: var(--line-strong);
    }
    .sheet-summary {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 6px;
    }
    .sheet-summary-name {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 14px;
    }
    .sheet-chevron {
      margin-left: auto;
      color: var(--ink-4);
      transition: transform 300ms;
      flex-shrink: 0;
    }
    .sidebar.sheet-open .sheet-chevron { transform: rotate(180deg); }

    /* Canvas corner overlays: hide both on mobile — technical info not needed on small screens */
    .canvas-overlay.corner-overlay { display: none; }

    /* Timezone row inside bottom sheet */
    .sheet-tz {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
      border-top: 1px solid var(--line);
      margin-top: 8px;
    }
    .sheet-label {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-4);
    }

    /* Legend: hide by default on mobile (accessible via sidebar) */
    .legend { display: none; }
    /* Scale bar stays visible */
  }

  @media (max-width: 479px) {
    .sim-clock .val { font-size: 10px; }
  }

  /* ── Floating Action Button (mobile LIVE toggle) ────────────── */
  .fab-live {
    position: fixed;
    bottom: calc(88px + env(safe-area-inset-bottom, 0px));
    right: 16px;
    z-index: 200;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    background: rgba(10, 10, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.10);
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    cursor: pointer;
    transition: all 0.2s ease;
    min-height: 44px;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    -webkit-user-select: none;
  }
  .fab-live.is-live {
    border-color: var(--cobalt);
    color: var(--ink);
  }
  .fab-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink-4);
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .fab-live.is-live .fab-dot {
    background: var(--green);
    animation: pulse-live 1.4s ease-in-out infinite;
  }
  /* Hide FAB on desktop */
  @media (min-width: 769px) {
    .fab-live { display: none; }
  }

  /* ── Timezone custom dropdown ───────────────────────────────── */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .tz-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    flex-shrink: 0;
    position: relative;
  }
  .tz-lbl {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-4);
  }
  .tz-dropdown { position: relative; }
  .tz-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 4px 10px;
    border-radius: var(--r-sm);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
    outline: none;
  }
  .tz-trigger:hover { border-color: var(--line-strong); color: var(--ink-2); }
  .tz-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 160px;
    background: var(--bg-2);
    border: 1px solid var(--line-strong);
    border-radius: var(--r-md);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 4px;
    z-index: 300;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    margin: 0;
    list-style: none;
  }
  .tz-menu.open {
    display: block;
    animation: fadeInDown 0.15s ease;
  }
  .tz-menu li {
    padding: 7px 12px;
    border-radius: var(--r-sm);
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    cursor: pointer;
    list-style: none;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
  }
  .tz-menu li:hover { background: rgba(255,255,255,0.05); color: var(--ink); }
  .tz-menu li.active { color: var(--cobalt-soft); background: rgba(26,108,246,0.08); }
  /* Hide topbar TZ wrap on mobile (lives in sidebar there) */
  @media (max-width: 767px) { .tz-wrap { display: none; } }
</style>

<div class="radar-shell">
  <div class="topbar" data-screen-label="02 Radar — Topbar">
    <div class="left">
      <a href="/" class="brand">
        <svg class="mark" viewBox="0 0 64 64" fill="none"><g transform="translate(32 32) rotate(-18)"><ellipse cx="0" cy="0" rx="26" ry="9" fill="none" stroke="currentColor" stroke-width="2.4"/><circle cx="18" cy="-5.4" r="2.2" fill="currentColor"/><circle cx="-15" cy="5.6" r="2.2" fill="currentColor"/></g><path d="M32 6 L34.6 30 L48 32 L34.6 34 L32 58 L29.4 34 L16 32 L29.4 30 Z" fill="currentColor"/></svg>
        <span class="name">NEO Radar</span>
      </a>
      <div class="links">
        <a href="/">Overview</a>
        <a href="/radar" class="active">Radar</a>
        <a href="/asteroid/99942">Catalog</a>
        <a href="/methodology">Methodology</a>
      </div>
    </div>
    <div class="sim-clock">
      <span class="lbl">Sim Time</span>
      <span class="val" id="sim-clock-val">2026·05·27 12:00 UTC</span>
    </div>
    <div class="tz-wrap">
      <span class="tz-lbl">Display timezone</span>
      <div class="tz-dropdown" id="tz-dropdown">
        <button class="tz-trigger" id="tz-trigger" type="button">
          <span id="tz-current">UTC</span>
