        <div style="padding:10px 12px;border:1px solid var(--line);border-radius:6px;"><div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.14em;color:var(--ink-4);text-transform:uppercase;margin-bottom:6px;">Method</div><div style="font-family:var(--font-mono);font-size:12px;">RK4</div></div>
        <div style="padding:10px 12px;border:1px solid var(--line);border-radius:6px;"><div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.14em;color:var(--ink-4);text-transform:uppercase;margin-bottom:6px;">CPU · 60 s</div><div style="font-family:var(--font-mono);font-size:12px;color:#6fb4ff;">1.2 %</div></div>
      </div>
