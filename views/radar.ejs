          </button>
          <ul class="tz-menu" id="tz-menu-mobile">
            <li data-tz="UTC">UTC</li>
            <li data-tz="America/Sao_Paulo">BRT (Brasília)</li>
            <li data-tz="America/New_York">EST (New York)</li>
            <li data-tz="America/Los_Angeles">PST (Los Angeles)</li>
            <li data-tz="Europe/London">GMT (London)</li>
            <li data-tz="Europe/Paris">CET (Paris)</li>
            <li data-tz="Asia/Tokyo">JST (Tokyo)</li>
            <li data-tz="Asia/Shanghai">CST (Shanghai)</li>
            <li data-tz="Australia/Sydney">AEST (Sydney)</li>
